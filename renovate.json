{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["mise"],
  "mise": {
    "managerFilePatterns": [
      "**/mise.toml",
      "**/.mise.toml",
      "**/mise/conf.d/*.toml",
      "**/.config/mise/conf.d/*.toml"
    ]
  }
}
